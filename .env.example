# Mealie connection
MEALIE_BASE_URL=http://your-mealie-host:9000/api
MEALIE_API_TOKEN=your_mealie_api_token
# Optional alias (compatible with mealie-organizer naming):
# MEALIE_API_KEY=your_mealie_api_token

# Parser behavior
CONFIDENCE_THRESHOLD=0.80
PARSER_STRATEGIES=nlp,openai
# FORCE_PARSER=nlp

# Runtime behavior
DELAY_SECONDS=0.10
PAGE_SIZE=200
MAX_RECIPES=
AFTER_SLUG=
DRY_RUN=false

# HTTP tuning
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRIES=3
REQUEST_BACKOFF_SECONDS=0.4

# Artifacts
OUTPUT_DIR=reports
LOW_CONFIDENCE_FILE=review_low_confidence.json
SUCCESS_FILE=parsed_success.log

# Docker runtime mode
RUN_MODE=loop
RUN_INTERVAL_SECONDS=21600
# Optional CLI args for containerized parser runs
# PARSER_ARGS=--verbose
